datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String     @id @default(uuid())
  fullName      String
  email         String     @unique
  phone         String?
  passwordHash  String
  avatarUrl     String?
  role          String     @default("ADMIN") // For fallback/compatibility
  isActive      Boolean    @default(true)
  isSystemAdmin Boolean    @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  createdBy     String?
  updatedBy     String?

  userRoles     UserRole[]
  auditLogs     AuditLog[]
  paymentRequests  PaymentRequest[]  @relation("Requester")
  approvedRequests PaymentRequest[]  @relation("Approver")
  createdVouchers  PaymentVoucher[]  @relation("VoucherCreator")

  @@map("Users")
}

model SiteSettings {
  id             String  @id @default(uuid())
  siteName       String
  slogan         String?
  primaryColor   String  @default("#4A250F")
  secondaryColor String  @default("#C96A24")
  accentColor    String  @default("#D99A2B")
  phone          String?
  email          String?
  address        String?
  facebookUrl    String?
  zaloUrl        String?
  googleMapUrl   String? @db.NVarChar(MAX)
  openingHours   String?
  seoTitle       String?
  seoDescription String? @db.NVarChar(MAX)
  seoKeywords    String? @db.NVarChar(MAX)
  faviconUrl     String?
  logoUrl        String?

  @@map("SiteSettings")
}

model Banner {
  id           String   @id @default(uuid())
  title        String
  subtitle     String?
  description  String?  @db.NVarChar(MAX)
  imageUrl     String
  buttonText   String?
  buttonLink   String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("Banners")
}

model NavigationItem {
  id           String   @id @default(uuid())
  label        String
  url          String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("NavigationItems")
}

model HomeSection {
  id           String   @id @default(uuid())
  sectionKey   String   @unique
  title        String
  subtitle     String?
  description  String?  @db.NVarChar(MAX)
  imageUrl     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("HomeSections")
}

model MenuCategory {
  id           String     @id @default(uuid())
  name         String
  description  String?    @db.NVarChar(MAX)
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  menuItems    MenuItem[]

  @@map("MenuCategories")
}

model MenuItem {
  id               String       @id @default(uuid())
  categoryId       String
  name             String
  slug             String       @unique
  imageUrl         String
  price            Decimal      @db.Decimal(18, 2)
  salePrice        Decimal?     @db.Decimal(18, 2)
  shortDescription String?      @db.NVarChar(MAX)
  description      String?      @db.NVarChar(MAX)
  ingredients      String?      @db.NVarChar(MAX)
  isFeatured       Boolean      @default(false)
  isAvailable      Boolean      @default(true)
  displayOrder     Int          @default(0)
  createdAt        DateTime     @default(now())
  category         MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("MenuItems")
}

model Promotion {
  id           String    @id @default(uuid())
  title        String
  description  String?   @db.NVarChar(MAX)
  imageUrl     String
  startDate    DateTime
  endDate      DateTime
  discountText String?
  buttonText   String?
  buttonLink   String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  @@map("Promotions")
}

model GalleryImage {
  id           String   @id @default(uuid())
  title        String?
  imageUrl     String
  altText      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("GalleryImages")
}

model Testimonial {
  id           String   @id @default(uuid())
  customerName String
  content      String   @db.NVarChar(MAX)
  rating       Int      @default(5)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("Testimonials")
}

model ContactMessage {
  id        String   @id @default(uuid())
  fullName  String
  phone     String
  email     String?
  message   String   @db.NVarChar(MAX)
  status    String   @default("NEW") // NEW, CONTACTED, DONE
  createdAt DateTime @default(now())

  @@map("ContactMessages")
}

model MediaFile {
  id           String   @id @default(uuid())
  fileName     String
  originalName String
  fileUrl      String
  mimeType     String
  size         Int
  altText      String?  @db.NVarChar(MAX)
  title        String?  @db.NVarChar(MAX)
  caption      String?  @db.NVarChar(MAX)
  createdAt    DateTime @default(now())

  @@map("MediaFiles")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  action       String
  entity       String?
  entityName   String?
  entityId     String?
  oldValue     String?  @db.NVarChar(MAX)
  newValue     String?  @db.NVarChar(MAX)
  oldValueJson String?  @db.NVarChar(MAX)
  newValueJson String?  @db.NVarChar(MAX)
  ipAddress    String?
  userAgent    String?  @db.NVarChar(MAX)
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("AuditLogs")
}

model BlogCategory {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  description  String?    @db.NVarChar(MAX)
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  posts        BlogPost[]

  @@map("BlogCategories")
}

model BlogPost {
  id             String       @id @default(uuid())
  categoryId     String
  title          String
  slug           String       @unique
  excerpt        String?      @db.NVarChar(MAX)
  content        String       @db.NVarChar(MAX)
  thumbnailUrl   String?
  coverImageUrl  String?
  authorName     String?
  status         String       @default("DRAFT")
  publishedAt    DateTime?
  readingTime    Int          @default(1)
  tags           String?      @db.NVarChar(MAX)
  seoTitle       String?
  seoDescription String?      @db.NVarChar(MAX)
  seoKeywords    String?      @db.NVarChar(MAX)
  canonicalUrl   String?
  ogTitle        String?
  ogDescription  String?      @db.NVarChar(MAX)
  ogImageUrl     String?
  schemaType     String       @default("BlogPosting")
  viewCount      Int          @default(0)
  isFeatured     Boolean      @default(false)
  displayOrder   Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  category       BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
  @@map("BlogPosts")
}

model SeoPage {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  excerpt        String?  @db.NVarChar(MAX)
  content        String   @db.NVarChar(MAX)
  coverImageUrl  String?
  seoTitle       String?
  seoDescription String?  @db.NVarChar(MAX)
  seoKeywords    String?  @db.NVarChar(MAX)
  canonicalUrl   String?
  ogTitle        String?
  ogDescription  String?  @db.NVarChar(MAX)
  ogImageUrl     String?
  schemaType     String   @default("Article")
  isPublished    Boolean  @default(true)
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("SeoPages")
}

model FAQ {
  id           String   @id @default(uuid())
  question     String   @db.NVarChar(MAX)
  answer       String   @db.NVarChar(MAX)
  pageSlug     String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("FAQs")
}

model CustomerReview {
  id           String   @id @default(uuid())
  customerName String
  rating       Int      @default(5)
  content      String   @db.NVarChar(MAX)
  avatar       String?
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("CustomerReviews")
}

// User role management tables
model Role {
  id           String           @id @default(uuid())
  code         String           @unique
  name         String
  description  String?          @db.NVarChar(MAX)
  isSystemRole Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("Roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("UserRoles")
}

model Menu {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  path      String?
  icon      String?
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  isVisible Boolean  @default(true)
  
  parent          Menu?            @relation("MenuToMenu", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children        Menu[]           @relation("MenuToMenu")
  rolePermissions RolePermission[]

  @@map("Menus")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?  @db.NVarChar(MAX)
  
  rolePermissions RolePermission[]

  @@map("Permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  menuId       String
  permissionId String
  isAllowed    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId, permissionId])
  @@map("RolePermissions")
}

// Payment/Expense management tables
model ExpenseCategory {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  group        String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentRequests PaymentRequest[]
  paymentVouchers PaymentVoucher[]

  @@map("ExpenseCategories")
}

model PaymentMethod {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentVouchers PaymentVoucher[]

  @@map("PaymentMethods")
}

model CashAccount {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  balance      Decimal  @default(0.0) @db.Decimal(18, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentVouchers PaymentVoucher[]

  @@map("CashAccounts")
}

model Supplier {
  id           String   @id @default(uuid())
  name         String
  phone        String?
  taxCode      String?
  address      String?
  currentDebt  Decimal  @default(0.0) @db.Decimal(18, 2)
  paymentTerm  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentRequests PaymentRequest[]

  @@map("Suppliers")
}

model PaymentRequest {
  id                String    @id @default(uuid())
  code              String    @unique
  requestDate       DateTime  @default(now())
  requesterId       String
  department        String
  expenseCategoryId String
  supplierId        String?
  amount            Decimal   @db.Decimal(18, 2)
  reason            String    @db.NVarChar(MAX)
  attachmentUrl     String?   @db.NVarChar(MAX)
  status            String    @default("PENDING") // DRAFT, PENDING, APPROVED, REJECTED, PAID, CANCELLED
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  requester       User             @relation("Requester", fields: [requesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver        User?            @relation("Approver", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expenseCategory ExpenseCategory  @relation(fields: [expenseCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier        Supplier?        @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentVouchers PaymentVoucher[]

  @@map("PaymentRequests")
}

model PaymentVoucher {
  id                String    @id @default(uuid())
  code              String    @unique
  paymentDate       DateTime  @default(now())
  paymentRequestId  String?
  recipientName     String
  reason            String    @db.NVarChar(MAX)
  amount            Decimal   @db.Decimal(18, 2)
  paymentMethodId   String
  cashAccountId     String
  expenseCategoryId String
  attachmentUrl     String?   @db.NVarChar(MAX)
  notes             String?   @db.NVarChar(MAX)
  status            String    @default("UNPOSTED") // UNPOSTED, POSTED (đối soát/ghi sổ)
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  paymentRequest  PaymentRequest?  @relation(fields: [paymentRequestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentMethod   PaymentMethod    @relation(fields: [paymentMethodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cashAccount     CashAccount      @relation(fields: [cashAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expenseCategory ExpenseCategory  @relation(fields: [expenseCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator         User             @relation("VoucherCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("PaymentVouchers")
}

// Attendance and payroll management tables
model WorkShift {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  startTime   String?
  endTime     String?
  hourlyRate  Decimal  @default(0.0) @db.Decimal(18, 2)
  description String?  @db.NVarChar(MAX)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   PayrollEmployee[]
  attendances AttendanceRecord[]

  @@map("WorkShifts")
}

model PayrollEmployee {
  id             String   @id @default(uuid())
  code           String   @unique
  fullName       String
  phone          String?
  position       String?
  defaultShiftId String?
  hourlyRate     Decimal? @db.Decimal(18, 2)
  note           String?  @db.NVarChar(MAX)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  defaultShift WorkShift?         @relation(fields: [defaultShiftId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  attendances  AttendanceRecord[]
  payrollLines PayrollLine[]

  @@map("PayrollEmployees")
}

model AttendanceRecord {
  id           String    @id @default(uuid())
  employeeId   String
  shiftId      String?
  workDate     DateTime
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int       @default(0)
  hourlyRate   Decimal   @default(0.0) @db.Decimal(18, 2)
  totalHours   Decimal   @default(0.0) @db.Decimal(10, 2)
  grossAmount  Decimal   @default(0.0) @db.Decimal(18, 2)
  note         String?   @db.NVarChar(MAX)
  status       String    @default("RECORDED")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shift    WorkShift?      @relation(fields: [shiftId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([workDate])
  @@index([employeeId, workDate])
  @@map("AttendanceRecords")
}

model PayrollRun {
  id          String   @id @default(uuid())
  code        String   @unique
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("DRAFT")
  totalHours  Decimal  @default(0.0) @db.Decimal(18, 2)
  totalAmount Decimal  @default(0.0) @db.Decimal(18, 2)
  note        String?  @db.NVarChar(MAX)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines PayrollLine[]

  @@index([periodStart, periodEnd])
  @@map("PayrollRuns")
}

model PayrollLine {
  id              String  @id @default(uuid())
  payrollRunId    String
  employeeId      String
  employeeCode    String
  employeeName    String
  position        String?
  shiftName       String?
  attendanceCount Int     @default(0)
  totalHours      Decimal @default(0.0) @db.Decimal(18, 2)
  hourlyRate      Decimal @default(0.0) @db.Decimal(18, 2)
  grossAmount     Decimal @default(0.0) @db.Decimal(18, 2)
  note            String? @db.NVarChar(MAX)

  payrollRun PayrollRun      @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([payrollRunId, employeeId])
  @@map("PayrollLines")
}
